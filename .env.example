# ============================================================
# 玄曜阁 · 环境变量配置
# 本地开发用 .env，生产环境（Railway）在 Dashboard 设置
# ============================================================

# ---------- Stripe 支付 ----------
# 密钥：本地用 sk_test_...，生产用 sk_live_...
# 获取：Stripe Dashboard → Developers → API Keys
STRIPE_SECRET_KEY=sk_test_xxx

# Webhook 密钥：用于验证支付回调
# 获取：Stripe Dashboard → Developers → Webhooks → Add endpoint
# Endpoint URL: https://你的域名/api/payment/webhook
# 记下 Signing secret (whsec_...)
STRIPE_WEBHOOK_SECRET=whsec_xxx

# 产品 Price ID（在 Stripe Dashboard → Products 创建）
STRIPE_PRICE_BAZI_REPORT=price_xxx    # 八字详批 ¥9.9
STRIPE_PRICE_LIUYAO_REPORT=price_xxx  # 六爻深度解读 ¥9.9
STRIPE_PRICE_FULL_REPORT=price_xxx    # 完整报告套餐 ¥19.9

# ---------- 站点配置 ----------
# 生产环境替换为 Railway 分配的域名
# 例如：https://xuanyao-ge.up.railway.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---------- AI 润色（可选） ----------
# 用于增强解读文案的自然度
ANTHROPIC_API_KEY=sk-ant-xxx
AI_MODEL=claude-sonnet-5
