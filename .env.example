# Stripe server key. Use sk_test_... locally, sk_live_... in production.
STRIPE_SECRET_KEY=sk_test_xxx

# Stripe Price IDs created in the Stripe Dashboard.
STRIPE_PRICE_BAZI_REPORT=price_xxx
STRIPE_PRICE_LIUYAO_REPORT=price_xxx
STRIPE_PRICE_FULL_REPORT=price_xxx

# Optional AI enhancement API.
ANTHROPIC_API_KEY=sk-ant-xxx
AI_MODEL=claude-sonnet-5
